# ---- API KEYS (required for each provider you want to use) ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ---- MODEL OVERRIDES (optional — sensible defaults are already set) ----
# Check https://docs.claude.com for the latest Claude model IDs before deploying,
# since Anthropic ships new model versions periodically.
OPENAI_MODEL=gpt-4o-mini
CLAUDE_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-1.5-flash

# Model used for the final synthesis step. Claude is recommended here because
# it tends to be strong at comparative reasoning / critique tasks.
SYNTHESIZER_MODEL=claude-sonnet-4-6
